        "jsCode": "const root = $input.first().json;\nconst clients = Array.isArray(root.data) ? root.data : [];\nconst lastSeenAt = new Date().toISOString();\nconst rows = clients.map((client) => ({\n  fc_client_id: Number(client.id),\n  company_id: client.company_id ?? null,\n  name: client.name,\n  is_archived: client.is_archived ?? null,\n  archived_at: client.archived_at ?? null,\n  created_at: client.created_at ?? null,\n  updated_at: client.updated_at ?? null,\n  raw: client,\n  last_seen_at: lastSeenAt,\n}));\nreturn [{ json: { rows, fcClientCount: rows.length, sample: rows.slice(0, 5) } }];\n"
