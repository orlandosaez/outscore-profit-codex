      "parameters": {
        "jsCode": "function dateOnly(value) {\n  if (!value) return null;\n  const date = new Date(value);\n  if (Number.isNaN(date.getTime())) return null;\n  return date.toISOString().slice(0, 10);\n}\nconst root = $input.first().json;\nconst projects = Array.isArray(root.data) ? root.data : [];\nconst lastSeenAt = new Date().toISOString();\nconst rows = projects.map((project) => ({\n  fc_project_id: Number(project.id),\n  fc_client_id: project.client?.id ?? project.client_id ?? null,\n  title: project.title,\n  template_id: project.template_id ?? null,\n  service_item_id: project.service_item_id ?? null,\n  is_closed: project.is_closed ?? project.closed ?? null,\n  closed_at: project.closed_at ?? null,\n  start_date: dateOnly(project.start_date),\n  due_date: dateOnly(project.due_date),\n  accounting_period: dateOnly(project.accounting_period),\n  accounting_period_date: dateOnly(project.accounting_period_date),\n  computed_accounting_period: dateOnly(project.computed_accounting_period),\n  created_at: project.created_at ?? null,\n  updated_at: project.updated_at ?? null,\n  raw: project,\n  last_seen_at: lastSeenAt,\n}));\nreturn [{ json: { rows, fcProjectCount: rows.length, sample: rows.slice(0, 5) } }];\n"
